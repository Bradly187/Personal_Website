# Example Nginx config for bradtarver.com
# Place at: /etc/nginx/conf.d/bradtarver.conf
# or replace the relevant server block in /etc/nginx/nginx.conf

server {
    listen 80;
    server_name bradtarver.com www.bradtarver.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name bradtarver.com www.bradtarver.com;

    ssl_certificate /etc/letsencrypt/live/bradtarver.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bradtarver.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/html;
    index index.html;

    # Custom 404
    error_page 404 /404.html;
    location = /404.html {
        internal;
    }

    # Cache static assets (images, PDF, fonts) for 7 days
    location ~* \.(png|jpg|jpeg|gif|svg|ico|pdf|woff2?|ttf|eot)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # Cache HTML/CSS/JS for 1 hour (allows quick updates)
    location ~* \.(html|css|js)$ {
        expires 1h;
        add_header Cache-Control "public, must-revalidate";
    }

    # Security headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location / {
        try_files $uri $uri/ =404;
    }
}
